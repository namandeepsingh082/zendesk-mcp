# Zendesk MCP Server — Credentials Template
# Copy this file to .env and fill in your real values
# NEVER commit the .env file to Git

# Your Zendesk subdomain (just "yourcompany" from yourcompany.zendesk.com)
ZENDESK_SUBDOMAIN=yourcompany

# Your Zendesk admin email
ZENDESK_EMAIL=you@yourcompany.com

# Your Zendesk API token
# Get it from: Admin Center → Apps & Integrations → APIs → Zendesk API → Add API token
ZENDESK_API_TOKEN=your_api_token_here

# Transport mode: "stdio" for Claude Desktop, "sse" for HTTP/browser access
# Default is "stdio" when installed via pip/uvx (for Claude Desktop)
TRANSPORT=stdio

# Port for SSE/HTTP mode (only used when TRANSPORT=sse)
PORT=8080
